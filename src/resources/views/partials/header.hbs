<nav class="navbar navbar-expand-lg bg-body-tertiary shadow-sm">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/">
            <i class="fas fa-graduation-cap me-2 text-primary"></i>Blog Khóa Học
        </a>
        <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarSupportedContent"
            aria-controls="navbarSupportedContent"
            aria-expanded="false"
            aria-label="Toggle navigation"
        >
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link" href="/">
                        <i class="fas fa-home me-1"></i>Trang chủ
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                {{#if currentUser}}
                <!-- Logged-in user menu -->
                <li class="nav-item dropdown">
                    <a
                        class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                        href="#"
                        role="button"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                    >
                        {{#if currentUser.avatar}}
                        <img
                            src="{{currentUser.avatar}}"
                            alt="{{currentUser.name}}"
                            class="rounded-circle"
                            width="30"
                            height="30"
                            style="object-fit: cover;"
                        />
                        {{else}}
                        <span
                            class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center fw-bold"
                            style="width:30px;height:30px;font-size:13px;"
                        >
                            {{currentUser.name.[0]}}
                        </span>
                        {{/if}}
                        <span class="d-none d-md-inline">{{currentUser.name}}</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <li class="px-3 py-2">
                            <p class="mb-0 fw-semibold small">{{currentUser.name}}</p>
                            <p class="mb-0 text-muted" style="font-size:12px;">{{currentUser.email}}</p>
                        </li>
                        <li><hr class="dropdown-divider my-1" /></li>
                        <li>
                            <a class="dropdown-item" href="/courses/create">
                                <i class="fas fa-plus-circle me-2 text-success"></i>Đăng khóa học
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/me/stored/courses">
                                <i class="fas fa-book me-2 text-primary"></i>Khóa học của tôi
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/me/trash/courses">
                                <i class="fas fa-trash me-2 text-warning"></i>Thùng rác
                            </a>
                        </li>
                        <li><hr class="dropdown-divider my-1" /></li>
                        <li>
                            <form action="/logout" method="POST">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fas fa-right-from-bracket me-2"></i>Đăng xuất
                                </button>
                            </form>
                        </li>
                    </ul>
                </li>
                {{else}}
                <!-- Guest: show login button -->
                <li class="nav-item">
                    <a class="btn btn-primary btn-sm px-3" href="/login">
                        <i class="fas fa-right-to-bracket me-2"></i>Đăng nhập
                    </a>
                </li>
                {{/if}}
            </ul>
        </div>
    </div>
</nav>
