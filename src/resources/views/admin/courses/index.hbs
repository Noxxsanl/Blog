<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title"><i class="fas fa-book-open me-2"></i>Manage Courses</h1>
        <p class="page-subtitle">{{#if filters.search}}Results for "{{filters.search}}"{{else}}All published courses{{/if}}</p>
    </div>
    <div class="page-header-right">
        <a href="/admin/courses/create" class="btn btn-primary btn-sm">
            <i class="fas fa-plus me-1"></i>Add Course
        </a>
        <a href="/admin/courses/trash" class="btn btn-outline-warning btn-sm">
            <i class="fas fa-trash me-1"></i>Trash ({{deletedCount}})
        </a>
    </div>
</div>

<!-- Main Card -->
<div class="panel-card">
    <div class="panel-card-header">
        <h2 class="panel-card-title">
            <i class="fas fa-list me-2 text-primary"></i>Course List
        </h2>
        <span class="text-muted small">{{courses.length}} course(s) found</span>
    </div>

    <!-- Filter Bar -->
    <div class="table-filter-bar">
        <form method="GET" action="/admin/courses" class="filter-form" id="courseFilterForm">
            <div class="filter-search">
                <i class="fas fa-search filter-search-icon"></i>
                <input
                    type="text"
                    name="search"
                    class="filter-input"
                    placeholder="Search by name..."
                    value="{{filters.search}}"
                    autocomplete="off"
                />
            </div>
            <select name="level" class="filter-select" onchange="this.form.submit()">
                <option value="">All Levels</option>
                <option value="Cơ bản" {{#if (eq filters.level 'Cơ bản')}}selected{{/if}}>Cơ bản</option>
                <option value="Trung cấp" {{#if (eq filters.level 'Trung cấp')}}selected{{/if}}>Trung cấp</option>
                <option value="Nâng cao" {{#if (eq filters.level 'Nâng cao')}}selected{{/if}}>Nâng cao</option>
            </select>
            <select name="status" class="filter-select" onchange="this.form.submit()">
                <option value="">All Status</option>
                <option value="published" {{#if (eq filters.status 'published')}}selected{{/if}}>Published</option>
                <option value="draft" {{#if (eq filters.status 'draft')}}selected{{/if}}>Draft</option>
                <option value="archived" {{#if (eq filters.status 'archived')}}selected{{/if}}>Archived</option>
            </select>
            <select name="sort" class="filter-select" onchange="this.form.submit()">
                <option value="newest" {{#if (eq filters.sort 'newest')}}selected{{/if}}>Newest First</option>
                <option value="oldest" {{#if (eq filters.sort 'oldest')}}selected{{/if}}>Oldest First</option>
            </select>
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="fas fa-filter me-1"></i>Filter
            </button>
            {{#if filters.search}}
            <a href="/admin/courses" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-times me-1"></i>Clear
            </a>
            {{/if}}
        </form>
    </div>

    <!-- Bulk Action Bar -->
    <form method="POST" action="/admin/courses/handle-form-actions" name="bulkForm" id="bulkForm">
        <div class="bulk-action-bar" id="bulkBar" style="display:none;">
            <span class="bulk-count" id="bulkCount">0 selected</span>
            <select name="action" class="filter-select" style="width:auto;">
                <option value="">Choose action</option>
                <option value="delete">Move to Trash</option>
            </select>
            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Apply bulk action?')">
                Apply
            </button>
            <button type="button" class="btn btn-outline-secondary btn-sm" id="clearSelection">
                Clear
            </button>
        </div>

        <div class="panel-card-body p-0">
            {{#if courses.length}}
            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th style="width:40px;">
                                <input type="checkbox" id="checkAll" class="form-check-input" />
                            </th>
                            <th>Course</th>
                            <th>Level</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th style="width:120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each courses}}
                        <tr>
                            <td>
                                <input type="checkbox" name="coursesIds[]" value="{{this._id}}" class="form-check-input course-checkbox" />
                            </td>
                            <td>
                                <div class="course-cell">
                                    <div class="course-thumb">
                                        {{#if this.image}}
                                        <img src="{{this.image}}" alt="{{this.name}}" />
                                        {{else}}
                                        <div class="course-thumb-fallback">
                                            <i class="fas fa-book"></i>
                                        </div>
                                        {{/if}}
                                    </div>
                                    <div class="course-info">
                                        <p class="course-name">{{truncate this.name 50}}</p>
                                        <p class="course-desc">{{truncate this.description 70}}</p>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-{{levelBadge this.level}}-subtle text-{{levelBadge this.level}} border border-{{levelBadge this.level}}-subtle fw-normal">
                                    {{this.level}}
                                </span>
                            </td>
                            <td>
                                <span class="status-dot status-{{defaultTo this.status 'published'}}"></span>
                                {{statusLabel (defaultTo this.status 'published')}}
                            </td>
                            <td class="text-muted small">{{formatDate this.createdAt}}</td>
                            <td>
                                <div class="action-btns">
                                    <a href="/courses/{{this.slug}}" class="action-btn action-btn-view" title="View public page" target="_blank">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="/admin/courses/{{this._id}}/edit" class="action-btn action-btn-edit" title="Edit">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <button type="button"
                                        class="action-btn action-btn-delete btn-delete-single"
                                        title="Delete"
                                        data-id="{{this._id}}"
                                        data-name="{{this.name}}">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{else}}
            <div class="empty-state">
                <i class="fas fa-book-open empty-state-icon"></i>
                <p class="empty-state-title">No courses found</p>
                <p class="empty-state-sub">
                    {{#if filters.search}}Try a different search term.{{else}}Get started by adding your first course.{{/if}}
                </p>
                <a href="/admin/courses/create" class="btn btn-primary btn-sm mt-2">
                    <i class="fas fa-plus me-1"></i>Add First Course
                </a>
            </div>
            {{/if}}
        </div>
    </form>
</div>

<!-- Hidden delete form for single-row delete -->
<form id="deleteSingleForm" method="POST" style="display:none;"></form>

<style>
.bulk-action-bar {
    padding: 10px 20px;
    background: #eff6ff;
    border-bottom: 1px solid #dbeafe;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
}
.bulk-count { font-weight: 600; color: #3b82f6; }
</style>

<script>
(function () {
    const checkAll = document.getElementById('checkAll');
    const checkboxes = document.querySelectorAll('.course-checkbox');
    const bulkBar = document.getElementById('bulkBar');
    const bulkCount = document.getElementById('bulkCount');
    const clearBtn = document.getElementById('clearSelection');

    function updateBulkBar() {
        const checked = document.querySelectorAll('.course-checkbox:checked').length;
        if (checked > 0) {
            bulkBar.style.display = 'flex';
            bulkCount.textContent = checked + ' selected';
        } else {
            bulkBar.style.display = 'none';
        }
        checkAll.checked = checked === checkboxes.length && checkboxes.length > 0;
        checkAll.indeterminate = checked > 0 && checked < checkboxes.length;
    }

    if (checkAll) {
        checkAll.addEventListener('change', function () {
            checkboxes.forEach(cb => cb.checked = this.checked);
            updateBulkBar();
        });
    }

    checkboxes.forEach(cb => cb.addEventListener('change', updateBulkBar));

    if (clearBtn) {
        clearBtn.addEventListener('click', function () {
            checkboxes.forEach(cb => cb.checked = false);
            if (checkAll) checkAll.checked = false;
            updateBulkBar();
        });
    }

    // Single-row delete
    document.querySelectorAll('.btn-delete-single').forEach(function (btn) {
        btn.addEventListener('click', function () {
            const id = this.getAttribute('data-id');
            const name = this.getAttribute('data-name');
            if (!confirm('Move "' + name + '" to trash?')) return;
            const form = document.getElementById('deleteSingleForm');
            form.action = '/admin/courses/' + id + '?_method=DELETE';
            form.method = 'POST';
            form.submit();
        });
    });

    // Filter search on Enter
    const searchInput = document.querySelector('.filter-input');
    if (searchInput) {
        searchInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); this.closest('form').submit(); }
        });
    }
})();
</script>
